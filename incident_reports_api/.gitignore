# =============================================================
#  .gitignore — Java / Spring Boot / Maven / Docker
# =============================================================
 
# ── Maven ─────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
 
# ── IDE ───────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
.vscode/
*.classpath
*.project
.settings/
.factorypath
 
# ── Spring Boot ───────────────────────────────────────────────
*.log
logs/
spring-shell.log
 
# ── Variables de entorno ──────────────────────────────────────
.env
!.env.example
 
# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
 
# ── Docker ────────────────────────────────────────────────────
docker/mysql_data/
 
# ── Compiled ──────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
